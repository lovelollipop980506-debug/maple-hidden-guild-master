# ============================================================
# SECRETS ONLY.
# Discord 연동 설정(서버/채널/역할 매핑)은 .env가 아니라
# 사이트의 /setup 부트스트랩에서 설정합니다 (DB에 저장).
# ============================================================

# ---- Discord OAuth (Developer Portal > Application > OAuth2) ----
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ---- Discord Bot (Developer Portal > Application > Bot) ----
# 봇 권한: View Channels, Read Message History, Send Messages, Manage Roles
# Privileged Gateway Intents: MESSAGE CONTENT INTENT 켜기 (채팅 수집에 필수)
DISCORD_BOT_TOKEN=

# ---- Auth.js (NextAuth v5) ----
# openssl rand -base64 32
AUTH_SECRET=
# 배포 주소 (로컬은 http://localhost:3000)
AUTH_URL=http://localhost:3000

# ---- Supabase (Project Settings > API) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_EVIDENCE_BUCKET=evidence
SUPABASE_CHAT_BUCKET=chat-images

# ---- 채팅 보관 기간(일). 0이면 영구 보관 ----
RETENTION_DAYS=90
