# ============================================================
# Discord OAuth (Developer Portal > Application > OAuth2)
# ============================================================
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Discord Bot (Developer Portal > Application > Bot)
# Bot must be invited to the guild with permissions:
#   View Channels, Read Message History (polling),
#   Send Messages (notifications), Manage Roles (auto role grant)
DISCORD_BOT_TOKEN=

# Your guild (server) ID
DISCORD_GUILD_ID=

# Channel(s) to ingest chat from (comma-separated channel IDs)
DISCORD_SOURCE_CHANNEL_IDS=

# Channel to post fallback notifications / announcements
DISCORD_NOTIFY_CHANNEL_ID=

# ============================================================
# Role mapping: Discord role IDs -> site permission tiers
# (comma-separated; a user with ANY listed role gets that tier)
# ============================================================
DISCORD_ADMIN_ROLE_IDS=
DISCORD_REVIEWER_ROLE_IDS=
DISCORD_MEMBER_ROLE_IDS=

# Role automatically granted to a user when their join application
# is approved (leave empty to disable auto-grant)
DISCORD_APPROVED_MEMBER_ROLE_ID=

# ============================================================
# Auth.js (NextAuth v5)
# Generate a secret with: openssl rand -base64 32
# ============================================================
AUTH_SECRET=
# Public site URL (e.g. https://your-site.netlify.app). For local dev use http://localhost:3000
AUTH_URL=http://localhost:3000

# ============================================================
# Supabase (Project Settings > API)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — SERVER ONLY, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=
# Storage bucket for skill/application evidence images
SUPABASE_EVIDENCE_BUCKET=evidence
# Storage bucket for re-hosted chat images (Discord URLs expire ~24h)
SUPABASE_CHAT_BUCKET=chat-images

# ============================================================
# Retention: auto-delete chat messages + images older than N days
# (keeps storage bounded / free forever). Set 0 to keep everything.
# ============================================================
RETENTION_DAYS=90
